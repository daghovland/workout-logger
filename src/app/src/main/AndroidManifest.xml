<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for Supabase sync + AI coaching -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Samsung Health SDK permissions -->
    <!-- These are declared here; runtime permission is requested via SamsungHealthRepository -->
    <uses-permission android:name="com.samsung.android.providers.context.permission.WRITE_USE_APP_FEATURE_SURVEY" />

    <application
        android:name=".WorkoutApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WorkoutLogger">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Deep-link for Supabase Google OAuth redirect.
                After sign-in, Google redirects to: no.daglifts.workout://login-callback
                Supabase redirectUri must be set to this in your Supabase dashboard under
                Auth > URL Configuration > Redirect URLs.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="no.daglifts.workout" android:host="login-callback" />
            </intent-filter>
        </activity>

        <!--
            Samsung Health SDK requires this service declaration.
            The HealthDataService connects your app to the Samsung Health app process.
        -->
        <!--
        <service
            android:name="com.samsung.android.sdk.healthdata.HealthDataService"
            android:exported="true" />
        -->

    </application>
</manifest>
