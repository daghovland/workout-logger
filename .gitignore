supabase/.temp

# ── Android ───────────────────────────────────────────────────────────────────

# Secrets & local machine paths — NEVER commit these
src/local.properties

# Gradle caches and build output
src/.gradle/
src/build/
src/app/build/

# Android Studio / IntelliJ project files (machine-specific)
src/.idea/
src/**/*.iml
src/captures/

# Samsung Health SDK AAR — proprietary binary, must be downloaded manually
# from developer.samsung.com (see src/SETUP.md)
src/app/libs/*.aar

# Gradle wrapper JAR (binary, regenerated by `gradle wrapper`)
src/gradle/wrapper/gradle-wrapper.jar
